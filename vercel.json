{
  "redirects": [
    {
      "source": "/podcasts",
      "destination": "/sources/podcasts",
      "permanent": true
    },
    {
      "source": "/how",
      "destination": "/how-it-works",
      "permanent": true
    },
    {
      "source": "/agents",
      "destination": "/developers",
      "permanent": true
    },
    {
      "source": "/agent-docs",
      "destination": "/developers",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/features-manifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/api/stats/downloads",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/blog/rss.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        }
      ]
    }
  ]
}

